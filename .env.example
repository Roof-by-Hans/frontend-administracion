# URL base del backend API
# En desarrollo local usa: http://localhost:3000/api
# En producción usa la URL de tu servidor
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000/api

# URL del servicio de tarjetas RFID
# En desarrollo local usa: http://localhost:3500/api
# En producción usa la URL de tu servidor de tarjetas
EXPO_PUBLIC_CARD_SERVICE_URL=http://localhost:3500/api

# Timeout para la lectura de tarjetas RFID en milisegundos
# Por defecto: 10000 (10 segundos)
EXPO_PUBLIC_RFID_TIMEOUT=10000
